{
    "name": "nlocascio/mindbody-laravel",
    "description": "Laravel wrapper for MINDBODY API",
    "keywords": [
        "laravel",
        "mindbody"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "Nick LoCascio",
            "email": "nlocascio@gmail.com"
        }
    ],
    "require": {
        "php": ">8.0",
        "ext-curl": "*",
        "ext-json": "*",
        "ext-mbstring": "*",
        "illuminate/support": ">=5.1",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "php": ">8.0",
        "orchestra/testbench": ">6.0",
        "phpunit/phpunit": "^8.0",
        "squizlabs/php_codesniffer": "~3",
        "friendsofphp/php-cs-fixer": "~3",
        "roave/security-advisories": "dev-master",
        "psy/psysh": "^0.10.9",
        "phpstan/phpstan": "^0.12.99"
    },
    "autoload": {
        "psr-4": {
            "Nlocascio\\Mindbody\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Nlocascio\\Mindbody\\Tests\\": "tests"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "extra": {
        "laravel": {
            "providers": [
                "Nlocascio\\Mindbody\\MindbodyServiceProvider"
            ],
            "aliases": {
                "Mbo": "Nlocascio\\Mindbody\\MBO"
            }
        }
    }
}
